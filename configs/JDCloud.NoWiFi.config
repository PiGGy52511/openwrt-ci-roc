# ==================== 平台架构 ====================
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_MULTI_PROFILE=y

# 只保留太乙（re-cs-07），其他设备注释掉（或删除）
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-ss-01=y
# CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02=y
# CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-02="luci-app-athena-led luci-i18n-athena-led-zh-cn"

CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-07=y

# ==================== 设备捆绑包（刷机即装） ====================
# 原只有 dockerman，现在加入 wireguard, ddns-go, mihomo
CONFIG_TARGET_DEVICE_PACKAGES_qualcommax_ipq60xx_DEVICE_jdcloud_re-cs-07=" \
luci-app-dockerman \
luci-app-wireguard \
luci-i18n-wireguard-zh-cn \
luci-app-ddns-go \
luci-app-mihomo \
"

# ==================== 硬件与驱动 ====================
# Wi-Fi 已禁用，内存配置也关闭（因为无 ath11k）
CONFIG_ATH11K_MEM_PROFILE_512M=n
CONFIG_NSS_FIRMWARE_VERSION_12_5=y

# ==================== 新增功能包（强制编译进固件） ====================
# WireGuard 全套
CONFIG_PACKAGE_kmod-wireguard=y
CONFIG_PACKAGE_wireguard-tools=y
CONFIG_PACKAGE_luci-app-wireguard=y
CONFIG_PACKAGE_luci-i18n-wireguard-zh-cn=y

# DDNS-GO
CONFIG_PACKAGE_luci-app-ddns-go=y

# Mihomo 核心及 Luci（需要 kenzo 源）
CONFIG_PACKAGE_luci-app-mihomo=y
CONFIG_PACKAGE_mihomo=y
CONFIG_PACKAGE_mihomo-geoip=y
CONFIG_PACKAGE_mihomo-geosite=y

# ==================== 你原有的其他包（保留） ====================
# 如果需要 athena-led，可以取消下面注释，否则删除
# CONFIG_PACKAGE_luci-app-athena-led=m
# CONFIG_PACKAGE_luci-i18n-athena-led-zh-cn=m
CONFIG_PACKAGE_luci-app-gecoosac=y   # 保留原配置
CONFIG_PACKAGE_luci-app-dockerman=m  # 会被 DEVICE_PACKAGES 强制覆盖为 y

# ==================== Wi-Fi 相关（全部禁用） ====================
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-qcn9074=n

# 额外禁用无线工具（可选，确保不残留）
CONFIG_PACKAGE_wpad-basic=n
CONFIG_PACKAGE_hostapd=n
CONFIG_PACKAGE_iw=n
CONFIG_PACKAGE_iwinfo=n

# ==================== 系统基础工具 ====================
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl-openssl=y
CONFIG_PACKAGE_block-mount=y       # 挂载 eMMC 剩余空间
CONFIG_PACKAGE_kmod-fs-ext4=y      # 支持 ext4
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-usb-storage=y  # 如果需要 USB 扩展
